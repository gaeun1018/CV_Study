import os
import json
import pandas as pd

data_path = '/kaggle/input/competitions/cassava-leaf-disease-classification'

df = pd.read_csv(os.path.join(data_path, 'train.csv'))

df.head()

print("데이터 크기:", df.shape)
print("컬럼:", df.columns)
print("라벨 종류:", df['label'].unique())
print("클래스 개수:", df['label'].nunique())

with open(os.path.join(data_path, 'label_num_to_disease_map.json')) as f:
    label_map = json.load(f)

print(label_map)

import matplotlib.pyplot as plt

label_counts = df['label'].value_counts().sort_index()

plt.figure()
label_counts.plot(kind='bar')
plt.title("Class Distribution")
plt.xlabel("Class")
plt.ylabel("Count")
plt.show()

from PIL import Image
import matplotlib.pyplot as plt

image_folder = os.path.join(data_path, 'train_images')

sample = df.sample(5)

plt.figure(figsize=(10,5))

for i, row in enumerate(sample.itertuples()):
    img_path = os.path.join(image_folder, row.image_id)
    img = Image.open(img_path)
    
    plt.subplot(1,5,i+1)
    plt.imshow(img)
    plt.title(f"label: {row.label}")
    plt.axis('off')

plt.show()
